# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_dev_saas

# Redis
REDIS_URL=redis://localhost:6379

# AI Models
OPENAI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o

# GitHub
GITHUB_TOKEN=ghp_your-token-here
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Notifications
SLACK_WEBHOOK_URL=
NOTIFY_EMAIL=
NOTIFY_WEBHOOK_URL=

# Metrics
METRICS_PORT=9090

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# AWS (for SOC2 Evidence + Multi-Account IAM)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# SOC2 Automated Evidence Pack
EVIDENCE_S3_BUCKET=your-tenant-soc2-evidence-bucket
EVIDENCE_RUN_NOW=false   # Set to "true" to trigger an immediate collection on startup

# Chaos Agent
CHAOS_RUN_NOW=false               # Set to "true" to trigger an experiment on startup
CHAOS_EXPERIMENT_TYPE=            # Leave blank for random, or specify: service_kill, latency_injection...
CHAOS_CRON=0 3 * * 0              # Default: every Sunday at 03:00 UTC

# Agent Prompt Self-Evolution
EVOLVE_RUN_NOW=false              # Set to "true" to trigger an analysis cycle on startup
EVOLVE_AUTO_APPLY=false           # WARNING: Set to "true" to auto-apply CRITICAL mutations
EVOLVE_ANALYSIS_DAYS=30           # Number of days of execution history to analyze
EVOLVE_CRON=0 4 * * 1            # Default: every Monday at 04:00 UTC

# Secret Vault Integration
# Provider: 'aws' (production), 'hashicorp' (on-prem), 'env' (local dev ONLY)
VAULT_PROVIDER=env
# AWS Secrets Manager (used when VAULT_PROVIDER=aws)
AWS_REGION=eu-west-1
# HashiCorp Vault (used when VAULT_PROVIDER=hashicorp)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your-vault-root-token
# Rotation check schedule
VAULT_ROTATION_CRON=0 5 * * *    # Daily at 05:00 UTC
